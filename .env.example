# No database — the app stores everything in memory (resets on restart).

# Google Gemini API key (https://aistudio.google.com/apikey).
# Leave empty to run in offline heuristic mode (no AI calls).
# IMPORTANT: the app defaults to gemini-2.5-flash. Some keys have no quota on
# gemini-2.0-flash and will 429 — keep 2.5-flash unless you know otherwise.
GEMINI_API_KEY=

# Set true to force the offline heuristic engine even when a key is present.
DEMO_MODE=false

# Optional overrides
# GEMINI_MODEL=gemini-2.5-flash
# CV_PARSE_BATCH_SIZE=6
# SHORTLIST_SIZE=10

# Backend
CORS_ORIGINS=http://localhost:3000
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
