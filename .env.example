# No database — the app stores everything in memory (resets on restart).

# Google Gemini (leave empty for demo mode with mock AI)
GEMINI_API_KEY=

# Demo mode uses mock AI when no API key is set
DEMO_MODE=true

# Backend
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=60

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
